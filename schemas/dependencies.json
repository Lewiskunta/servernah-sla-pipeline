{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://servernah.atlancis.internal/schemas/dependencies/v1",
  "title": "Dependencies",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "apiVersion",
    "kind",
    "metadata"
  ],
  "properties": {
    "apiVersion": {
      "type": "string",
      "const": "resilience/v1"
    },
    "kind": {
      "type": "string",
      "enum": ["Infrastructure", "Software", "External"]
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["service_ref"],
      "properties": {
        "service_ref": {
          "type": "string",
          "pattern": "^[a-z0-9-]{3,64}$"
        }
      }
    },
    "physical_nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["component_id", "name", "datacenter_zone", "role", "criticality", "rto_minutes", "weight"],
        "properties": {
          "component_id": {
            "type": "string",
            "pattern": "^infra-[a-z0-9-]+-[a-z]{3,4}-[0-9]{2}$"
          },
          "name": {
            "type": "string",
            "minLength": 2,
            "maxLength": 128
          },
          "datacenter_zone": {
            "type": "string",
            "enum": ["adc-primary", "paix-failover"]
          },
          "role": {
            "type": "string",
            "enum": ["hypervisor", "storage-node", "network-node", "management-node"]
          },
          "criticality": {
            "type": "string",
            "enum": ["hard", "soft"]
          },
          "rto_minutes": {
            "type": "integer",
            "minimum": 1,
            "maximum": 1440
          },
          "weight": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "redundancy": {
            "type": "string",
            "enum": ["active-active", "active-passive", "none"]
          }
        }
      }
    },
    "network_links": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["component_id", "name", "provider", "link_type", "criticality", "rto_minutes", "weight"],
        "properties": {
          "component_id": {
            "type": "string",
            "pattern": "^net-[a-z0-9-]+-[0-9]{2}$"
          },
          "name": {
            "type": "string",
            "minLength": 2,
            "maxLength": 128
          },
          "provider": {
            "type": "string",
            "minLength": 2,
            "maxLength": 128
          },
          "link_type": {
            "type": "string",
            "enum": ["mpls-vpls", "dark-fibre", "broadband", "sd-wan", "dedicated-ethernet"]
          },
          "criticality": {
            "type": "string",
            "enum": ["hard", "soft"]
          },
          "rto_minutes": {
            "type": "integer",
            "minimum": 1,
            "maximum": 1440
          },
          "weight": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    },
    "software_components": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["component_id", "name", "type", "criticality", "rto_minutes", "weight"],
        "properties": {
          "component_id": {
            "type": "string",
            "pattern": "^sw-[a-z0-9-]+-[0-9]{2}$"
          },
          "name": {
            "type": "string",
            "minLength": 2,
            "maxLength": 128
          },
          "type": {
            "type": "string",
            "enum": [
              "compute-service",
              "network-service",
              "storage-service",
              "identity-service",
              "image-service",
              "placement-service",
              "control-plane",
              "message-broker",
              "database",
              "operating-system"
            ]
          },
          "version": {
            "type": "string",
            "maxLength": 32
          },
          "criticality": {
            "type": "string",
            "enum": ["hard", "soft"]
          },
          "rto_minutes": {
            "type": "integer",
            "minimum": 1,
            "maximum": 1440
          },
          "weight": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    },
    "external_dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["component_id", "name", "vendor_type", "criticality", "vendor_rto_minutes", "weight"],
        "properties": {
          "component_id": {
            "type": "string",
            "pattern": "^ext-[a-z0-9-]+-[0-9]{2}$"
          },
          "name": {
            "type": "string",
            "minLength": 2,
            "maxLength": 128
          },
          "vendor_type": {
            "type": "string",
            "enum": ["wan-provider", "colocation", "dns-provider", "ntp-provider", "certificate-authority", "upstream-isp"]
          },
          "endpoint": {
            "type": "string",
            "pattern": "^https://[a-z0-9./-]+$"
          },
          "auth_method": {
            "type": "string",
            "enum": ["mtls", "api-key", "oauth2", "none"]
          },
          "criticality": {
            "type": "string",
            "enum": ["hard", "soft"]
          },
          "vendor_rto_minutes": {
            "type": "integer",
            "minimum": 1,
            "maximum": 10080
          },
          "weight": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "escalation_track": {
            "type": "string",
            "enum": ["p1-critical", "p2-high", "p3-standard"]
          }
        }
      }
    },
    "compliance_mandates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["mandate_id", "standard", "scope"],
        "properties": {
          "mandate_id": {
            "type": "string",
            "pattern": "^comp-[a-z0-9-]+-[0-9]{2}$"
          },
          "standard": {
            "type": "string",
            "enum": ["iso-27001", "pci-dss", "gdpr", "ndpr", "hipaa", "sox"]
          },
          "scope": {
            "type": "string",
            "minLength": 5,
            "maxLength": 256
          }
        }
      }
    }
  }
}